GEMINI_API_KEY=

# FastAPI base URL for Next.js rewrites (``/api/awa/*`` → Awa API).
AWA_API_ORIGIN=http://127.0.0.1:8080

ELEVENLABS_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_TTS_VOICE_ID=
ELEVENLABS_TTS_MODEL=
# Optional TTS voice_settings (omit all to use ElevenLabs voice defaults). Suggested “interviewer” try:
# ELEVENLABS_TTS_STABILITY=0.45
# ELEVENLABS_TTS_STYLE=0.2
# ELEVENLABS_TTS_SPEED=0.95
# ELEVENLABS_TTS_SIMILARITY_BOOST=0.75
# ELEVENLABS_TTS_USE_SPEAKER_BOOST=true
# Optional override for the voice client (default ``scribe_v1``).
NEXT_PUBLIC_ELEVENLABS_STT_MODEL=
# Voice UI: show "Raw trace" (STT + SSE) by default when ``1`` or ``true``.
NEXT_PUBLIC_AWA_VOICE_DEBUG=