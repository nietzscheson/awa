meta {
  name: Create Session
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/sessions
  body: json
  auth: none
}

body:json {
  {
    "session_id": "{{sessionId}}",
    "user_id": "{{userId}}",
    "language": "es-MX",
    "metadata": {
      "source": "bruno"
    }
  }
}

headers {
  Content-Type: application/json
}

script:pre-request {
  bru.setVar("sessionId", bru.interpolate("{{$randomUUID}}"));
  bru.setVar("userId", bru.interpolate("{{$randomUUID}}"));
}
